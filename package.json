{
  "name": "@v11/peer-daw",
  "version": "1.0.0",
  "description": "V11 Peer DAW - Modular peer-to-peer audio workstation with collaborative sessions",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "test": "node --experimental-vm-modules $(which node) node_modules/.bin/jest",
    "test:watch": "pnpm test --watch",
    "test:coverage": "pnpm test --coverage",
    "clean": "rm -rf dist node_modules"
  },
  "keywords": [
    "daw",
    "audio",
    "music",
    "peer-to-peer",
    "modular",
    "synthesizer",
    "sequencer",
    "collaborative"
  ],
  "author": "V11 Collective",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "peerjs": "^1.5.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.14.4"
}
